# ───────── App ─────────
NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:3000
WEB_PUBLIC_URL=http://localhost:3000
WEBHOOK_PUBLIC_URL=http://localhost:3001

# Public (web)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ───────── Database ─────────
DATABASE_URL=postgresql://diyaa:diyaa@localhost:5432/diyaa?schema=public
DIRECT_URL=postgresql://diyaa:diyaa@localhost:5432/diyaa?schema=public

# ───────── Redis ─────────
REDIS_URL=redis://localhost:6379

# ───────── Auth ─────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-please-use-32+
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-please-use-32+
ACCESS_TTL=15m
REFRESH_TTL=7d
ALLOW_AGENCY_SIGNUP=true
SUPERADMIN_BOOTSTRAP_EMAIL=admin@diyaa.ai
SUPERADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-boot

# ───────── Evolution API (WhatsApp) ─────────
EVOLUTION_API_URL=https://wa.example.com
EVOLUTION_API_KEY=change-me-evolution-key

# ───────── AI ─────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
SARVAM_API_KEY=

# ───────── Email (Resend) ─────────
RESEND_API_KEY=
EMAIL_FROM=noreply@diyaa.ai

# ───────── Billing (Razorpay) ─────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PLAN_STARTER_PRICE_ID=
PLAN_GROWTH_PRICE_ID=
PLAN_SCALE_PRICE_ID=

# ───────── Optional integrations (Phase 4+) ─────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SHOPIFY_API_KEY=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=


# ───────── App URLs ─────────
API_PUBLIC_URL=http://localhost:3001

# ───────── Encryption (32+ chars) ─────────
ENCRYPTION_KEY=change-me-encryption-key-must-be-32-chars-or-more

# ───────── OAuth: Google ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/calendar.readonly

# ───────── OAuth: Zoho ─────────
ZOHO_SCOPES=ZohoCRM.modules.ALL,ZohoCRM.users.READ

# ───────── OAuth: Shopify ─────────
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,read_customers,read_products


# ───────── Meta WhatsApp Cloud API (official) ─────────
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=change-me-to-a-random-string
# Optional platform-wide system user token; otherwise per-account tokens are stored encrypted.
META_SYSTEM_USER_TOKEN=


# ───────── Global API rate limit ─────────
# Per-IP request cap per minute. 0 disables.
GLOBAL_RATE_LIMIT_PER_MIN=300
GLOBAL_RATE_LIMIT_AUTHED_PER_MIN=1200


# ───────── Meta Embedded Signup ─────────
# App ID + secret from your Facebook App. Configure WhatsApp Embedded Signup
# in App settings → WhatsApp → Embedded Signup → copy the configuration ID.
META_APP_ID=
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_EMBEDDED_SIGNUP_REDIRECT_URI=https://www.facebook.com/connect/login_success.html
