{
  "name": "diyaa-whatsapp-saas",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "ioredis": "5.4.1"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @diyaa/db prisma:generate",
    "db:migrate": "pnpm --filter @diyaa/db prisma:migrate",
    "db:deploy": "pnpm --filter @diyaa/db prisma:deploy",
    "db:studio": "pnpm --filter @diyaa/db prisma:studio"
  },
  "dependencies": {
    "next": "14.2.35"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20"
  }
}
